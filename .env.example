# ── Supabase ────────────────────────────────────────────────
# 프로젝트 URL은 공개돼도 무방
NEXT_PUBLIC_SUPABASE_URL=

# 서버 전용 시크릿 키. 절대 NEXT_PUBLIC_ 붙이지 말 것.
# 신규 프로젝트는 sb_secret_... (구 service_role 대체). 둘 중 하나만 채움.
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=

# 브라우저는 supabase-js를 쓰지 않지만, @supabase/ssr 서버 인증(OAuth·세션)에는
# anon 키가 서버 전용 변수로 필요. 절대 NEXT_PUBLIC_ 붙이지 말 것(브라우저 노출 금지).
SUPABASE_ANON_KEY=

# ── Rate limiting (Upstash Redis) ───────────────────────────
# Vercel의 Upstash 통합을 연결하면 KV_REST_API_URL / KV_REST_API_TOKEN 으로 자동 주입됨.
# 수동(로컬) 설정 시 아래 UPSTASH_ 이름도 인식한다(코드가 둘 다 받음).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ── 영수증 OCR (Google Gemini) ──────────────────────────────
# 영수증 사진 → 메뉴·금액 추출(Gemini 2.5 Flash-Lite). 서버 전용 — 절대 NEXT_PUBLIC_ 금지.
# 무료 키 발급: https://aistudio.google.com/apikey (결제수단 없이 무료 티어 가능)
GEMINI_API_KEY=

# ── 배포 URL (OG 절대경로/딥링크 fallback용) ─────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── (선택) V1+ 카카오 공유 SDK ──────────────────────────────
# NEXT_PUBLIC_KAKAO_JS_KEY=

# ── (선택) Cron 보호용 시크릿 ───────────────────────────────
# CRON_SECRET=
